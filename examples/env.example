# Docker Compose env file for mainnet-equivalent stack.
# Copy to .env:  cp examples/env.example examples/.env
# Used with: docker compose --env-file examples/.env -f examples/docker-compose-main.yml up -d
#
# Variables without defaults in docker-compose-main.yml — MUST be set here:
RETH_IMAGE=ghcr.io/paradigmxyz/reth:v2.3.0
LIGHTHOUSE_IMAGE=sigp/lighthouse:v8.1.3
FEE_RECIPIENT=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
#
# Variables with defaults in compose YAML (${VAR:-default}) — optional overrides:
# RETH_HTTP_PORT=1545
# RETH_WS_PORT=1546
# AUTHRPC_PORT=1551
# BN_HTTP_PORT=1052
# DEV_BLOCK_TIME=2s

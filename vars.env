# Docker-only L1 — no local reth/lighthouse binaries required.
#
# Dev Tier 2 genesis (Docker):
#   bash docker-setup-genesis.sh
#
# Mainnet-equivalent: bash examples/docker-setup-genesis.sh
#
# Start: docker compose --profile <dev|full> up -d
# Mainnet: docker compose -f examples/docker-compose-main.yml up -d
#
# ROOT_DIR is set by docker-setup-genesis.sh before this file is sourced.

JWT_FILE="${JWT_FILE:-$ROOT_DIR/jwt.hex}"
GENESIS_FILE="${GENESIS_FILE:-$ROOT_DIR/genesis.json}"
TESTNET_DIR="${TESTNET_DIR:-$ROOT_DIR/testnet}"

RETH_DATADIR="${RETH_DATADIR:-$ROOT_DIR/reth-data}"
BEACON_DATADIR="${BEACON_DATADIR:-$ROOT_DIR/beacon-data}"
VC_DATADIR="${VC_DATADIR:-$ROOT_DIR/validator-data}"

# --- Network params (dev) ---
CHAIN_ID="${CHAIN_ID:-12345}"
VALIDATOR_COUNT="${VALIDATOR_COUNT:-1}"
SECONDS_PER_SLOT="${SECONDS_PER_SLOT:-12}"
GENESIS_DELAY="${GENESIS_DELAY:-30}"
DEV_BLOCK_TIME="${DEV_BLOCK_TIME:-2s}"

FEE_RECIPIENT="${FEE_RECIPIENT:-0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266}"

# --- Pre-funded accounts (execution genesis alloc) ---
# Derived from MNEMONIC via m/44'/60'/0'/0/N (Hardhat / Anvil path).
# Rendered into GENESIS_FILE by scripts/render-genesis.sh before node start.
MNEMONIC="${MNEMONIC:-test test test test test test test test test test test junk}"
GENESIS_ACCOUNT_COUNT="${GENESIS_ACCOUNT_COUNT:-4}"
GENESIS_ACCOUNT_BALANCE_ETH="${GENESIS_ACCOUNT_BALANCE_ETH:-1000000}"
# Optional comma-separated per-account ETH balances (overrides GENESIS_ACCOUNT_BALANCE_ETH).
# Example: GENESIS_ACCOUNT_BALANCES_ETH="1000000,500000,100,0"
GENESIS_ACCOUNT_BALANCES_ETH="${GENESIS_ACCOUNT_BALANCES_ETH:-1000000,1000000,1000000,1000000}"

LCLI_VALIDATORS_BASE="${LCLI_VALIDATORS_BASE:-$ROOT_DIR}"
VALIDATORS_DIR="${VALIDATORS_DIR:-$LCLI_VALIDATORS_BASE/node_1/validators}"
SECRETS_DIR="${SECRETS_DIR:-$LCLI_VALIDATORS_BASE/node_1/secrets}"

# --- Ports ---
RETH_HTTP_PORT="${RETH_HTTP_PORT:-1545}"
RETH_WS_PORT="${RETH_WS_PORT:-1546}"
AUTHRPC_PORT="${AUTHRPC_PORT:-1551}"
BN_HTTP_PORT="${BN_HTTP_PORT:-1052}"

# --- Images (pinned for reproducibility; bump intentionally when upgrading) ---
RETH_IMAGE="${RETH_IMAGE:-ghcr.io/paradigmxyz/reth:v2.3.0}"
LIGHTHOUSE_IMAGE="${LIGHTHOUSE_IMAGE:-sigp/lighthouse:v8.1.3}"
LCLI_IMAGE="${LCLI_IMAGE:-abelian-lcli:latest}"

# Docker Compose interpolation (optional).
# docker-up.sh exports these from vars.env automatically; copy to .env only if you
# run bare `docker compose` without docker-up.sh.
#
# All fields have defaults set in vars.env or compose-env.sh.
# Required = must be explicitly set (no usable default). Optional = default is fine for dev.

# ─── Docker Images (pin for reproducibility) ───────────────────────────
# Required: no (defaults in compose-env.sh)
RETH_IMAGE=ghcr.io/paradigmxyz/reth:v2.3.0
#   Execution client image (Reth). Bump intentionally when upgrading.
LIGHTHOUSE_IMAGE=sigp/lighthouse:v8.1.3
#   Consensus client image (Lighthouse). Bump intentionally when upgrading.
LCLI_IMAGE=abelian-lcli:latest
#   lcli image built from docker/Dockerfile.lcli. Used by genesis setup only.

# ─── Network / Chain ───────────────────────────────────────────────────
# Required: no
CHAIN_ID=12345
#   EVM chain ID for the devnet. Default: 12345 (dev), 31337 (mainnet-eq).
VALIDATOR_COUNT=1
#   Number of Lighthouse validators. Default: 1.
SECONDS_PER_SLOT=12
#   Seconds per beacon slot (mainnet=12). Default: 12.
GENESIS_DELAY=30
#   Seconds from now until genesis (must be > docker-compose start time). Default: 30.
DEV_BLOCK_TIME=2s
#   Auto-mining block interval for Tier 1 (reth --dev). Default: 2s.
FEE_RECIPIENT=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
#   Validator fee recipient address. Required for validator_client.

# ─── Ports ─────────────────────────────────────────────────────────────
# Required: no (change only if ports conflict)
RETH_HTTP_PORT=1545
#   Reth JSON-RPC HTTP port exposed to host. Default: 1545.
RETH_WS_PORT=1546
#   Reth WebSocket port exposed to host. Default: 1546.
AUTHRPC_PORT=1551
#   Reth Engine API (authrpc) port for CL<->EL communication. Default: 1551.
BN_HTTP_PORT=1052
#   Beacon node HTTP API port exposed to host. Default: 1052.

# ─── File Paths (resolved relative to repo root) ───────────────────────
# Required: no (defaults in vars.env use ROOT_DIR)
JWT_FILE=jwt.hex
#   32-byte hex secret for Engine API JWT auth. Generated by genesis setup. Default: $ROOT_DIR/jwt.hex.
GENESIS_FILE=genesis.json
#   Execution layer genesis file (alloc + chain config). Default: $ROOT_DIR/genesis.json.
TESTNET_DIR=testnet
#   Lighthouse testnet configuration directory. Default: $ROOT_DIR/testnet.
RETH_DATADIR=reth-data
#   Reth data directory on host. Default: $ROOT_DIR/reth-data.
BEACON_DATADIR=beacon-data
#   Lighthouse beacon node data directory. Default: $ROOT_DIR/beacon-data.
VC_DATADIR=validator-data
#   Lighthouse validator client data directory. Default: $ROOT_DIR/validator-data.

# ─── Genesis Account Allocation ────────────────────────────────────────
# Required: no (dev defaults use Hardhat mnemonic)
MNEMONIC=test test test test test test test test test test test junk
#   BIP-39 mnemonic for deriving pre-funded accounts (m/44'/60'/0'/0/N).
#   Default: Hardhat/Anvil test mnemonic.
GENESIS_ACCOUNT_COUNT=4
#   Number of pre-funded accounts to derive from MNEMONIC. Default: 4.
GENESIS_ACCOUNT_BALANCE_ETH=1000000
#   Default ETH balance per pre-funded account. Default: 1,000,000 ETH.
GENESIS_ACCOUNT_BALANCES_ETH=1000000,1000000,1000000,1000000
#   Comma-separated per-account ETH balances. Overrides GENESIS_ACCOUNT_BALANCE_ETH
#   when set. Length must match GENESIS_ACCOUNT_COUNT. Default: 1M ETH each.

# ─── Validator Keystore Paths ──────────────────────────────────────────
# Required: no (defaults in vars.env use ROOT_DIR)
LCLI_VALIDATORS_BASE=.
#   Base directory containing node_1/validators and node_1/secrets. Default: $ROOT_DIR.
VALIDATORS_DIR=node_1/validators
#   Validator keystore directory (generated by lcli insecure-validators). Default: $LCLI_VALIDATORS_BASE/node_1/validators.
SECRETS_DIR=node_1/secrets
#   Validator secrets directory (generated by lcli insecure-validators). Default: $LCLI_VALIDATORS_BASE/node_1/secrets.

# ─── Script Runtime ────────────────────────────────────────────────────
# Required: no
# VARS_ENV=examples/vars.mainnet-equivalent.env
#   Alternative vars file (used instead of ROOT_DIR/vars.env). Set before calling
#   docker-up.sh or docker-setup-genesis.sh. Example values:
#     examples/vars.mainnet-equivalent.env
# COMPOSE_FILE=examples/docker-compose-main.yml
#   Alternative compose file (used by reset-dev.sh). Example values:
#     examples/docker-compose-main.yml
